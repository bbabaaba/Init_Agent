{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/init-agent/seen-items.schema.json",
  "title": "SeenItemsLedger",
  "description": "Incremental ledger for AI skills and GitHub discoveries",
  "type": "object",
  "required": ["version", "items"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/item" }
    }
  },
  "$defs": {
    "itemStatus": {
      "type": "string",
      "enum": ["pending_review", "promoted", "archived", "duplicate_of"]
    },
    "itemType": {
      "type": "string",
      "enum": ["repo", "issue", "discussion", "skill_file"]
    },
    "scores": {
      "type": "object",
      "required": ["solidness", "novelty", "maintenance", "community", "composite"],
      "additionalProperties": false,
      "properties": {
        "solidness": { "type": "number", "minimum": 0, "maximum": 10 },
        "novelty": { "type": "number", "minimum": 0, "maximum": 10 },
        "maintenance": { "type": "number", "minimum": 0, "maximum": 10 },
        "community": { "type": "number", "minimum": 0, "maximum": 10 },
        "composite": { "type": "number", "minimum": 0, "maximum": 10 },
        "evaluated_at": { "type": "string", "format": "date" },
        "notes": { "type": "string" }
      }
    },
    "changelogEntry": {
      "type": "object",
      "required": ["date", "content_hash", "note"],
      "additionalProperties": false,
      "properties": {
        "date": { "type": "string", "format": "date" },
        "content_hash": { "type": "string", "pattern": "^sha256:" },
        "note": { "type": "string" }
      }
    },
    "item": {
      "type": "object",
      "required": [
        "id",
        "type",
        "url",
        "title",
        "summary",
        "topics",
        "first_seen",
        "last_seen",
        "content_hash",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Dedup key: owner/repo, full URL, or owner/repo:path/to/SKILL.md"
        },
        "type": { "$ref": "#/$defs/itemType" },
        "url": { "type": "string", "format": "uri" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "topics": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "first_seen": { "type": "string", "format": "date" },
        "last_seen": { "type": "string", "format": "date" },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "status": { "$ref": "#/$defs/itemStatus" },
        "scores": {
          "oneOf": [{ "$ref": "#/$defs/scores" }, { "type": "null" }]
        },
        "supersedes": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        },
        "duplicate_of": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        },
        "stars": { "type": "integer", "minimum": 0 },
        "changelog": {
          "type": "array",
          "items": { "$ref": "#/$defs/changelogEntry" }
        }
      }
    }
  }
}
